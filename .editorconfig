# .editorconfig

# Top-most EditorConfig file
root = true

# Set default charset
[*]
charset = utf-8

# Set default end-of-line style
end_of_line = lf

# Set default indentation style and size
indent_style = space
indent_size = 2

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
